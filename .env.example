# ============================================================
# Personal-KB 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# -------------------- 项目配置 --------------------
PROJECT_NAME=Personal-KB
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# -------------------- PostgreSQL --------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=personal_kb
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=kb_password

# -------------------- Redis --------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -------------------- MinIO --------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kb-assets
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000

# -------------------- Qdrant --------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kb_chunks
QDRANT_VECTOR_SIZE=1024

# -------------------- Model Gateway --------------------
MODEL_GATEWAY_URL=http://localhost:8900
DEFAULT_LLM=qwen3:8b
DEFAULT_EMBEDDING=bge-m3
DEFAULT_RERANK=qwen3-reranker-0.6b

# -------------------- 存储路径 --------------------
UPLOAD_DIR=./uploads
NAS_MOUNT_PATH=/mnt/nas
LOCAL_STORAGE_PATH=./storage

# -------------------- 切片参数 --------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
VECTOR_TOP_K=40
BM25_TOP_K=40
RERANK_TOP_K=8
MAX_CONTEXT_TOKENS=6000

# -------------------- OCR / ASR --------------------
PADDLEOCR_LANG=ch
WHISPER_MODEL=medium
FFMPEG_PATH=ffmpeg

# -------------------- JWT --------------------
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# -------------------- DashScope --------------------
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
